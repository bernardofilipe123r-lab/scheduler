{
  "hooks": {
    "PostToolUse": [
      {
        "event": "PostToolUse",
        "type": "command",
        "command": "bash .github/hooks/scripts/post-edit-validate.sh",
        "osx": "bash .github/hooks/scripts/post-edit-validate.sh",
        "timeout": 30,
        "matchers": {
          "toolName": ["replace_string_in_file", "create_file", "multi_replace_string_in_file"]
        }
      }
    ]
  }
}
